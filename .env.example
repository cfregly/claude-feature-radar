# Copy this file to .env and paste your keys. .env is git-ignored. Never commit it.
#
# The core Claude demo (make demo) needs only the Anthropic key.
# The cross-platform comparison (make compare / make sweep) also needs the OpenAI and Gemini keys.
#
# Anthropic: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI:    https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Gemini:    https://aistudio.google.com/apikey
GEMINI_API_KEY=...
