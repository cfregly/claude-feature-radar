.venv/
.env
__pycache__/
*.pyc
.DS_Store
memories/

# data/ is transient per-run scratch (benchmark receipts, last_*.json). It is
# rewritten every run, so it stays out of git.
data/

# The per-edge product-team notes are the internal both-directions read (where a
# competitor or a do-it-yourself path matches or beats Claude). The engine still
# writes and reads them locally, but they never ship on the public surface, which
# carries only verified wins.
edges/*/PRODUCT_EMAIL.md

# state/ and landscape/ are the durable spine and MUST be committed. The diff
# baseline (landscape/landscape.json) and the coverage ledger (state/coverage.jsonl)
# have to survive a clone, or the "diff against the last run" and "never repeat an
# edge" premises break on a fresh checkout. They are NOT under data/, on purpose.
!state/
!landscape/

# Internal both-directions analysis stays local; the public tree ships only verified
# wins. The engine's own publish gate (engine/publish_brief.py) refuses these four
# edges as regime-bounded or parity, the analytical briefs carry the where-Claude-ties
# read, and the per-run CHANGELOG and edge-landscape brief are rewritten every sweep.
edges/cost-model/
edges/parity-gated/
edges/eval-quality/
edges/retention-resume/
briefs/*-edge-landscape.md
briefs/*-edge-landscape-master.md
briefs/2026-06-17-platform-edge.md
briefs/2026-06-17-sharpest-edge.md
briefs/2026-06-17-verified-picture.md
landscape/CHANGELOG-*.md
